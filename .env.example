# ─────────────────────────────────────────────────────────────
# Taya Dashboard — إعدادات الجلب المحلي
# انسخ هذا الملف إلى .env واملأ القيم. لا تدفع .env إلى git أبداً.
# ─────────────────────────────────────────────────────────────

# مسار ملف Chrome profile المخصّص المسجَّل دخوله في بسيطة (persistent user-data-dir).
# يُنشأ ويُسجَّل الدخول فيه مرة واحدة عبر:  python fetcher/fetch.py --login
TAYA_CHROME_PROFILE=/Users/<owner>/Library/Application Support/taya-chrome-profile

# نطاق الجلب الأولي بالأشهر (أول تشغيل)، ثم يصبح incremental بعد آخر تاريخ مخزّن.
TAYA_CUTOFF_MONTHS=24

# مصدر بسيطة (لا تغيّره إلا لو تغيّر النطاق).
PASEETAH_BASE=https://paseetah.com

# مركز نطاق طايا الصناعية (احتياطي bounding box).
TIC_LAT=24.4887
TIC_LNG=46.8813

# ── إشعار انتهاء الجلسة (اختياري) ──
# اترك NOTIFY_EMAIL فارغاً لتعطيل البريد؛ إشعار macOS يعمل دائماً عبر osascript.
NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
